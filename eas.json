{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "NODE_ENV": "development" }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "env": { "NODE_ENV": "production" }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.0",
      "env": { "NODE_ENV": "production" }
    }
  },
  "submit": {
    "production": {}
  }
}
